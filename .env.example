# 仅供本地合成数据开发。复制为 .env 后，替换所有 CHANGE_ME 值。
QA_APP_ENV=local
QA_LOG_LEVEL=INFO
QA_API_PORT=8000
QA_WEB_PORT=3000

# 本机可使用 SQLite；Compose 会覆盖为 PostgreSQL。
QA_DATABASE_URL=sqlite+pysqlite:///./.local/qa.db
QA_AUTO_CREATE_SCHEMA=true
QA_SEED_DEMO_DATA=true

# 生产必须关闭开发令牌，并配置企业 OIDC/JWKS。
QA_DEV_AUTH_ENABLED=true
QA_OIDC_ISSUER=http://127.0.0.1:9002/
QA_OIDC_AUDIENCE=enterprise-qa-api
QA_OIDC_JWKS_URL=
QA_DEV_JWT_SECRET=CHANGE_ME_AT_LEAST_32_RANDOM_CHARACTERS
QA_CURSOR_SIGNING_KEY=CHANGE_ME_DIFFERENT_32_RANDOM_CHARACTERS
QA_WEB_PUBLIC_URL=http://127.0.0.1:3000
QA_OIDC_CLIENT_ID=enterprise-qa-web

# S2 Model Gateway：本地默认只用确定性 Fake Provider。
QA_FAKE_MODEL_ENABLED=true
QA_MODEL_PROVIDER_ENABLED=false
QA_MODEL_PROVIDER_BASE_URL=
QA_MODEL_PROVIDER_API_KEY=
QA_MODEL_PROVIDER_MODEL=
QA_MODEL_CONNECT_TIMEOUT_SECONDS=5
QA_MODEL_FIRST_TOKEN_TIMEOUT_SECONDS=10
QA_MODEL_TOTAL_TIMEOUT_SECONDS=60
QA_MODEL_MAX_ATTEMPTS=3
QA_MODEL_MAX_CONCURRENCY=8
QA_CHAT_REQUESTS_PER_MINUTE=30
QA_CHAT_TENANT_CONCURRENCY=8
QA_CHAT_USER_CONCURRENCY=2
QA_CHAT_MAX_INPUT_TOKENS=4096
QA_CHAT_MAX_OUTPUT_TOKENS=1024

# S3 document ingestion. Compose overrides endpoints to MinIO and uses Fake Embedding locally.
QA_OBJECT_STORE_BACKEND=local
QA_OBJECT_STORE_LOCAL_ROOT=.local/objects
QA_OBJECT_STORE_ENDPOINT_URL=
QA_OBJECT_STORE_PUBLIC_ENDPOINT_URL=
QA_OBJECT_STORE_ACCESS_KEY=
QA_OBJECT_STORE_SECRET_KEY=
QA_OBJECT_STORE_QUARANTINE_BUCKET=qa-quarantine
QA_OBJECT_STORE_PUBLISHED_BUCKET=qa-published
QA_OBJECT_STORE_AUTO_CREATE_BUCKETS=true
QA_UPLOAD_PUBLIC_BASE_URL=http://127.0.0.1:3000/api/qa
QA_UPLOAD_PRESIGN_SECONDS=900
QA_INGESTION_MAX_UPLOAD_BYTES=10485760
QA_INGESTION_MAX_ATTEMPTS=3
QA_INGESTION_JOB_LEASE_SECONDS=120
QA_INGESTION_WORKER_POLL_SECONDS=1
QA_MALWARE_SCANNER_BACKEND=signature
QA_CLAMAV_HOST=
QA_CLAMAV_PORT=3310
QA_CLAMAV_TIMEOUT_SECONDS=15
QA_CHUNK_MAX_TOKENS=256
QA_CHUNK_OVERLAP_TOKENS=32
QA_FAKE_EMBEDDING_ENABLED=true
QA_EMBEDDING_PROVIDER_ENABLED=false
QA_EMBEDDING_PROVIDER_BASE_URL=
QA_EMBEDDING_PROVIDER_API_KEY=
QA_EMBEDDING_PROVIDER_MODEL=
QA_EMBEDDING_DIMENSIONS=16

# S4 grounded RAG. Fake reranker is deterministic and local-only.
QA_RAG_ENABLED=true
QA_RETRIEVAL_VECTOR_CANDIDATES=20
QA_RETRIEVAL_LEXICAL_CANDIDATES=20
QA_RETRIEVAL_RERANK_CANDIDATES=12
QA_RETRIEVAL_FINAL_K=5
QA_RETRIEVAL_RRF_K=60
QA_RETRIEVAL_CONTEXT_MAX_TOKENS=1200
QA_RETRIEVAL_MIN_RELEVANCE=0.28
QA_RETRIEVAL_MIN_QUERY_COVERAGE=0.34
QA_CITATION_MAX_QUOTE_CHARS=1200
QA_FAKE_RERANKER_ENABLED=true
QA_RERANKER_PROVIDER_ENABLED=false
QA_RERANKER_PROVIDER_BASE_URL=
QA_RERANKER_PROVIDER_API_KEY=
QA_RERANKER_PROVIDER_MODEL=
QA_RERANKER_TIMEOUT_SECONDS=20

# S5 local structural evaluator. Production must use an approved external evaluation worker.
QA_LOCAL_GOVERNANCE_EVALUATOR_ENABLED=true

# S6 local quality gate and OpenTelemetry. Local evaluator is forbidden in staging/production.
QA_LOCAL_QUALITY_EVALUATOR_ENABLED=true
QA_LOCAL_RELEASE_ORCHESTRATOR_ENABLED=true
QA_TELEMETRY_EXPORT_ENABLED=false
QA_OTEL_EXPORTER_OTLP_ENDPOINT=
QA_OTEL_SERVICE_NAME=enterprise-qa-api
QA_RELEASE_REVISION=s7-local-unknown
QA_TELEMETRY_METRIC_EXPORT_INTERVAL_MS=10000

# Compose 基础设施；这些值不是生产凭据。
POSTGRES_DB=enterprise_qa
POSTGRES_USER=enterprise_qa
POSTGRES_PASSWORD=CHANGE_ME_LOCAL_POSTGRES_PASSWORD
REDIS_PASSWORD=CHANGE_ME_LOCAL_REDIS_PASSWORD
MINIO_ROOT_USER=CHANGE_ME_LOCAL_MINIO_USER
MINIO_ROOT_PASSWORD=CHANGE_ME_LOCAL_MINIO_PASSWORD
